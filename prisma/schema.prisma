generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

model Bike {
  id         String      @id @default(cuid())
  make       String
  model      String
  plateNo    String      @unique
  engineNo   String
  chassisNo  String
  color      String
  agreements Agreement[]
}

model Customer {
  id          String      @id @default(cuid())
  firstName   String
  lastName    String
  nationality String
  email       String
  phone       String
  address     String
  hotel       String
  docType     String
  docNumber   String
  agreements  Agreement[]
}

model Agreement {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])

  bikeId      String?
  bike        Bike?     @relation(fields: [bikeId], references: [id])

  startTime   DateTime?
  endTime     DateTime?
  ratePerDay  Float?
  totalDays   Int?
  totalAmount Float?
  deposit     Float?
  fuelLevel   String?

  status      String    @default("PENDING")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  password       String
  role           Role      @default(STAFF)
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id            String   @id @default(cuid())
  sessionToken  String   @unique
  userId        String
  expires       DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}